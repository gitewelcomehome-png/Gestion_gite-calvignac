# ================================================================
# SÉCURITÉ - IMPORTANT
# ================================================================
# 
# ⚠️ La clé SUPABASE_KEY (anon) est PUBLIQUE par design
#    → C'est NORMAL qu'elle soit visible côté client
#    → Sécurité assurée par RLS policies Supabase
#    → NE JAMAIS utiliser la clé "service_role" côté client
#
# 🔒 Pour renforcer la sécurité:
#    1. Activer RLS sur toutes les tables (✅ fait)
#    2. Configurer Domain Restrictions dans Supabase Dashboard
#    3. Activer API Rate Limiting dans Supabase
#    4. Monitorer les logs d'accès Supabase
#
# ================================================================

# ================================================================
# CONFIGURATION EMAILS (Système de Ticketing Automatique)
# ================================================================
#
# Configuration SMTP pour l'envoi automatique d'emails
# Utilisé par: api/send-email.js pour notifications clients
#
# ================================================================

# Provider SMTP (choisir selon votre service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application

# Expéditeur des emails automatiques
SMTP_FROM="Support Gîtes <support@votre-domaine.com>"

# ================================================================
# RESEND (Notifications clients - api/send-notification.js)
# ================================================================
# Créez un compte sur https://resend.com et générez une clé API
# Configurer dans Vercel Dashboard > Settings > Environment Variables
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=notifications@liveownerunit.fr
RESEND_FROM_NAME=Gîte Welcome Home

# --- GUIDES DE CONFIGURATION PAR PROVIDER ---

# GMAIL :
# 1. Activer authentification 2FA
# 2. https://myaccount.google.com/apppasswords
# 3. Créer mot de passe d'application
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# OUTLOOK :
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587

# SENDGRID :
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey

# OVH :
# SMTP_HOST=ssl0.ovh.net
# SMTP_PORT=587

# MAILGUN :
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587

# ================================================================
# TESTER LA CONFIGURATION EMAIL
# ================================================================
# 
# curl -X POST http://localhost:3000/api/send-email \
#   -H "Content-Type: application/json" \
#   -d '{"to":"test@example.com","template":"error-notification","data":{...}}'
#
# ================================================================
